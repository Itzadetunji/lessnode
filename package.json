{
	"name": "lessnode",
	"version": "1.0.0",
	"description": "A lightweight utility package for Node.js.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "bunx tsc --project tsconfig.json",
		"typecheck": "bunx tsc --noEmit",
		"clean": "rm -rf dist",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"keywords": [
		"bun",
		"typescript",
		"node"
	],
	"engines": {
		"bun": ">=1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/node": "^26.1.0",
		"typescript": "latest"
	},
	"dependencies": {
		"@clack/prompts": "^1.7.0",
		"picocolors": "^1.1.1"
	}
}

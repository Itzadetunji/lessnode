{
	"name": "lessnode",
	"version": "0.2.6",
	"description": "Interactive CLI to find and safely delete node_modules folders from selected directories on macOS.",
	"author": "Adetunji Adeyinka",
	"license": "MIT",
	"type": "module",
	"homepage": "https://github.com/Itzadetunji/lessnode#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Itzadetunji/lessnode.git"
	},
	"bugs": {
		"url": "https://github.com/Itzadetunji/lessnode/issues"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"lessnode": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "bunx tsc --project tsconfig.json",
		"typecheck": "bunx tsc --noEmit",
		"clean": "rm -rf dist",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"keywords": [
		"cli",
		"bun",
		"node-modules",
		"cleanup",
		"disk-space",
		"developer-tools",
		"macos",
		"typescript",
		"node"
	],
	"engines": {
		"bun": ">=1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/node": "^26.1.0",
		"typescript": "latest"
	},
	"dependencies": {
		"@clack/prompts": "^1.7.0",
		"picocolors": "^1.1.1"
	}
}
